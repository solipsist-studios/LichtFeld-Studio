.video-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 12dp;
    margin-bottom: 8dp;
}

.video-card {
    width: 160dp;
    cursor: pointer;
}

.video-card:hover .card-body {
    border-color: #89b4fa;
    background-color: #313244;
}

.card-body {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 90dp;
    background-color: #1e1e2e;
    border-width: 1dp;
    border-color: #45475a;
    transition: background-color border-color 0.12s quadratic-out;
}

.play-icon {
    font-size: 28dp;
    color: #89b4fa;
}

.card-title {
    display: block;
    font-size: 11dp;
    color: #a6adc8;
    margin-top: 4dp;
    text-align: center;
}

.wiki-link {
    cursor: pointer;
}

.wiki-link:hover {
    text-decoration: underline;
}
